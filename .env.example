# NeuroForm Environment Configuration
# Copy this file to .env and fill in your values.

# Neo4j Connection
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here

# Set to "true" to disable Neo4j (graceful degradation)
# DISABLE_NEO4J=false

# Ollama Configuration
OLLAMA_MODEL=llama3
